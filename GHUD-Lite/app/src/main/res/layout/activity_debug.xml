<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Debug Information"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- OSM Debug Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OpenStreetMap Debug"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#E3F2FD"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/osmLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/osmSpeedLimit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Speed Limit: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/osmCameras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cameras Found: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/osmNearestCamera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nearest Camera: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/osmUpdateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Update: -"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Navigation Debug Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Navigation Debug"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#E8F5E9"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/navPackage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Package: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Title: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Text: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navBigText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BigText: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginVertical="8dp" />

            <TextView
                android:id="@+id/navParsedInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Parsed Instruction: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navParsedDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Parsed Distance: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navParsedEta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Parsed ETA: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navUpdateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Update: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/navLaneMask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lane Mask: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navLaneCandidates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lane Candidates: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navLanePayload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lane Payload: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navLaneBeforeExclusion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lane Before Exclusion: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/navLaneAfterExclusion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lane After Exclusion: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btnToggleLaneExclusion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lane Exclusion: ON"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Extracted Arrow Image:"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <ImageView
                android:id="@+id/navArrowImage"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:background="#DDDDDD"
                android:scaleType="fitCenter"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:id="@+id/navArrowScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/navArrowGallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Virtual HUD Preview -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Виртуальный HUD (предпросмотр)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#000000"
                android:padding="8dp">

                <!-- (5) Direction Arrow - Big on the left -->
                <TextView
                    android:id="@+id/vHudDirection"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="#11FFFFFF"
                    android:gravity="center"
                    android:text="↑"
                    android:textColor="#00FF00"
                    android:textSize="50sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- (1) Distance to next turn - Top Right -->
                <LinearLayout
                    android:id="@+id/vHudDistanceContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    
                    <TextView
                        android:id="@+id/vHudDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500"
                        android:textColor="#00FF00"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    
                    <TextView
                        android:id="@+id/vHudDistanceUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="#00FF00"
                        android:textSize="16sp"
                        android:layout_marginStart="2dp"
                        android:layout_gravity="center_vertical"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- (2) ETA/Time - Below distance -->
                <TextView
                    android:id="@+id/vHudEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:20"
                    android:textColor="#00FF00"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/vHudDistanceContainer" />

                <!-- (3) Speed & Speed Limit - Bottom Right -->
                <LinearLayout
                    android:id="@+id/vHudSpeedContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    
                    <TextView
                        android:id="@+id/vHudSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="64"
                        android:textColor="#00FF00"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/"
                        android:textColor="#00FF00"
                        android:textSize="24sp"
                        android:fontFamily="monospace"
                        android:layout_marginHorizontal="2dp" />
                    
                    <TextView
                        android:id="@+id/vHudSpeedLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="65"
                        android:textColor="#00FF00"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Status Icons - Top Center -->
                <LinearLayout
                    android:id="@+id/vHudIconsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    app:layout_constraintEnd_toStartOf="@id/vHudDistanceContainer"
                    app:layout_constraintStart_toEndOf="@id/vHudDirection"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/vHudIconCamera"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#00FF00"
                        android:visibility="invisible"
                        android:layout_marginEnd="6dp"/>

                    <ImageView
                        android:id="@+id/vHudIconSpeeding"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="#FF0000"
                        android:visibility="invisible"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <!-- Maneuver Details Section (NEW!) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Детали маневра"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FCE4EC"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/maneuverDirection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Direction Code: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/maneuverDirectionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Direction Name: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/maneuverDistanceMeters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Distance (meters): -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/maneuverDistanceFormatted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Distance (formatted): -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/maneuverInstructionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Instruction: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/maneuverArrowHash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Arrow Hash: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/maneuverArrowRecognized"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Arrow Recognized: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Internal Logs Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Internal Logs (DebugLog)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFF9C4"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/debugLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No logs yet..."
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:maxLines="200"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- Arrow Training Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Обучение (Train Arrow)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#E1BEE7"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/trainingArrowHashDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Текущий хеш: -"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerArrowTypes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnTrainArrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Запомнить (Save)"
                android:backgroundTint="#AB47BC"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HUD Library Icons/Symbols"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#D1C4E9"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select any icon/symbol from HudIcon library and send it to Bluetooth HUD"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerHudIcons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSendHudIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send Selected Icon/Symbol to HUD"
                android:backgroundTint="#7E57C2"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- HUD Debug Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HUD Output Debug"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFF3E0"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/hudSpeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Speed: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/hudSpeedLimit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Displayed Speed Limit: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/hudSpeedingIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Speeding Icon: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/hudCameraIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Camera Icon: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/hudDirection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Direction: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/hudDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Distance: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/hudLastCommand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Command: -"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/hudUpdateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last Update: -"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ECEFF1"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manual HUD Direction (Bluetooth)"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/inputManualType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type (e.g. 128 or 0x80)"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/inputManualAngle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Angle (e.g. 64 or 0x40)"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSendManualDirection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send Type/Angle to HUD"
                android:backgroundTint="#607D8B"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E0F7FA"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ShowGpsLabel(bool bShow)"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payload: 07 01 for true, 07 00 for false"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/inputGpsLabelFlag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="true or false"
                android:text="true"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSendGpsLabelFlag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send ShowGpsLabel Flag"
                android:backgroundTint="#00838F"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F3E5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manual SetTime payload"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fixed bytes: 0x05 ... 0x00. Select traffic/h1/h2/colon/m1/m2/flag."
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="traffic" />
            <Spinner
                android:id="@+id/spinnerSetTimeTraffic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="h1" />
            <Spinner
                android:id="@+id/spinnerSetTimeH1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="h2" />
            <Spinner
                android:id="@+id/spinnerSetTimeH2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="colon" />
            <Spinner
                android:id="@+id/spinnerSetTimeColon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="m1" />
            <Spinner
                android:id="@+id/spinnerSetTimeM1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="m2" />
            <Spinner
                android:id="@+id/spinnerSetTimeM2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="flag" />
            <Spinner
                android:id="@+id/spinnerSetTimeFlag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSendSetTimeRaw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send SetTime payload"
                android:backgroundTint="#7B1FA2"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8EAF6"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manual eLane (Lane Masks)"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Arrow Mask (active lane)"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerLaneArrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Outline Mask (all visible lanes)"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerLaneOutline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSendLaneMasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send eLane Masks to HUD"
                android:backgroundTint="#3949AB"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SetLanes string (up to 6 chars: 0/1/space; auto-normalized). Example: 010011 -> payload 02 7E 26"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/inputLaneBinary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="010011"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSendLaneString"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send SetLanes(String)"
                android:backgroundTint="#5C6BC0"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStartScreenCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Включить захват экрана"
            android:backgroundTint="#C8E6C9"
            android:textColor="#1B5E20"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Обновить"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnAppSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Настройки приложений"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClearLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Очистить логи"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnToggleDump"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toggle UI Dump (для поиска resource-id)"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnToggleNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toggle NotificationListener (вкл/выкл)"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnResetConfigs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сбросить конфиги (Reset Configs)"
            android:backgroundTint="#FFCDD2"
            android:textColor="#B71C1C"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnToggleToasts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toggle Debug Toasts"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
