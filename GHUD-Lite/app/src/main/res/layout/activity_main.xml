<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/main_content_horizontal_padding"
        android:paddingEnd="@dimen/main_content_horizontal_padding"
        android:paddingTop="@dimen/main_content_vertical_padding"
        android:paddingBottom="@dimen/main_content_vertical_padding"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Статус: Не подключено"
            android:textSize="18sp"
            android:padding="12dp"
            android:background="#E0E0E0"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Services Status Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сервисы Навигации"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Notification Listener -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                
                <View
                    android:id="@+id/indicatorNotification"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="#FF5252" 
                    android:layout_marginEnd="12dp"/>
                    
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Чтение уведомлений"
                    android:textSize="14sp"/>
                    
                <Button
                    android:id="@+id/btnEnableNotification"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Настроить"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Accessibility Service -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                
                <View
                    android:id="@+id/indicatorAccessibility"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="#FF5252"
                    android:layout_marginEnd="12dp"/>
                    
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Анализ экрана"
                    android:textSize="14sp"/>
                    
                <Button
                    android:id="@+id/btnEnableAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Включить"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Screen Capture -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <View
                    android:id="@+id/indicatorScreenCapture"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="#FF5252"
                    android:layout_marginEnd="12dp"/>
                    
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Захват экрана (Стрелки)"
                    android:textSize="14sp"/>
                    
                <Button
                    android:id="@+id/btnEnableScreenCapture"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Запуск"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnSelectHud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выбрать HUD"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />
            
        <Button
            android:id="@+id/btnRestartHud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Перезагрузить HUD"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Показывать время"
                android:textSize="16sp" />
                
            <Switch
                android:id="@+id/switchTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Показывать скорость"
                android:textSize="16sp" />
                
            <Switch
                android:id="@+id/switchSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ручной лимит скорости"
                android:textSize="16sp" />
                
            <Switch
                android:id="@+id/switchManualSpeedLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        
        <LinearLayout
            android:id="@+id/layoutSpeedLimitControl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:id="@+id/textSpeedLimitValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="71 км/ч"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
                
            <SeekBar
                android:id="@+id/seekBarSpeedLimit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="150"
                android:progress="71"/>
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Порог превышения"
                android:textSize="16sp" 
                android:layout_marginBottom="4dp"/>
                
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/textSpeedingThresholdValue"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="+10 км/ч"
                    android:textSize="14sp"
                    android:gravity="end"
                    android:layout_marginEnd="8dp"/>
                    
                <SeekBar
                    android:id="@+id/seekBarSpeedingThreshold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="30"
                    android:progress="10"/>
            </LinearLayout>
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Авто-яркость"
                android:textSize="16sp" />
                
            <Switch
                android:id="@+id/switchAutoBrightness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Интеграция с навигацией (Gmaps/Yandex)"
                android:textSize="16sp" />
                
            <Switch
                android:id="@+id/switchGmaps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Распознавание из уведомлений Яндекс"
                android:textSize="16sp" />
                
            <Switch
                android:id="@+id/switchYandexNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Активность сервиса"
                android:textSize="16sp"
                android:textStyle="bold" />
                
            <Switch
                android:id="@+id/switchService"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDebug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Debug Information"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnAppSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙ Настройки Приложений"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnOsmSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗺️ Настройки OSM"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_open_icon_mapping"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Icon Mappings (Capture)"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_open_gallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Все иконки HUD (Gallery)"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLayoutEditor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎨 Конструктор Экрана"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnStartScreenCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📸 Start Arrow Recognition"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
