                        {
                          "type": "text",
                          "text": "Попробовать",
                          "text_color": "#CC000000",
                          "font_size": 14,
                          "line_height": 16,
                          "font_weight": "bold",
                          "text_alignment_horizontal": "center",
                          "border": {
                            "corner_radius": 160
                          },
                          "action_animation": {
                            "name": "native"
                          },
                          "accessibility": {
                            "type": "button",
                            "mode": "merge",
                            "description": "Попробовать Про"
                          },
                          "action": {
                            "log_id": "paywall_button_try_alice_pro",
