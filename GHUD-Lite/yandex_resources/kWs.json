{
  "palette": {
    "dark": [
      {
        "color": "#0F1119",
        "name": "paywall.background"
      },
      {
        "color": "#CCFFFFFF",
        "name": "paywall.title"
      },
      {
        "color": "#191830",
        "name": "paywall.base_container.background"
      }
    ],
    "light": [
      {
        "color": "#FFFFFF",
        "name": "paywall.background"
      },
      {
        "color": "#CC000000",
        "name": "paywall.title"
      },
      {
        "color": "#F2F0FF",
        "name": "paywall.base_container.background"
      }
    ]
  },
  "templates": {
    "alice_tooltip": {
      "type": "container",
      "items": [
        {
          "type": "tooltip_block",
          "margins": {
            "top": 7
          }
        }
      ],
      "orientation": "overlap",
      "width": {
        "type": "wrap_content"
      },
      "default_state_id": "top"
    },
    "tooltip_block": {
      "type": "text",
      "background": [
        {
          "type": "solid",
          "$color": "tintColor"
        }
      ],
      "border": {
        "corner_radius": 10
      },
      "font_size": 13,
      "font_size_unit": "dp",
      "font_weight": "regular",
      "line_height": 16,
      "paddings": {
        "top": 8,
        "bottom": 8,
        "left": 12,
        "right": 12
      },
      "text_alignment_horizontal": "center",
      "text_alignment_vertical": "center",
      "width": {
        "type": "wrap_content"
      },
      "$text": "textValue",
      "$text_color": "textColor"
    },
    "list_item": {
      "type": "container",
      "orientation": "horizontal",
      "content_alignment_vertical": "center",
      "items": [
        {
          "type": "image",
          "image_url": "empty://",
          "$preview": "list_item_icon",
          "width": {
            "type": "fixed",
            "value": 24
          },
          "height": {
            "type": "fixed",
            "value": 24
          }
        },
        {
          "type": "text",
          "$text": "list_item_title",
          "$text_color": "list_item_text_color",
          "font_size": 13,
          "line_height": 16,
          "font_weight": "bold",
          "text_alignment_horizontal": "left",
          "paddings": {
            "top": 8,
            "bottom": 8
          },
          "margins": {
            "left": 12
          },
          "width": {
            "type": "match_parent"
          },
          "$ranges": "ranges_actions",
          "$images": "images_icon"
        }
      ]
    }
  },
  "card": {
    "log_id": "alice_v2_div_paywall",
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "container",
          "visibility_action": {
            "log_id": "paywall_shown"
          },
          "background": [
            {
              "type": "solid",
              "color": "@{paywall.background}"
            }
          ],
          "height": {
            "type": "match_parent"
          },
          "paddings": {
            "top": 16
          },
          "items": [
            {
              "type": "container",
              "id": "title",
              "width": {
                "type": "match_parent"
              },
              "orientation": "horizontal",
              "content_alignment_vertical": "center",
              "margins": {
                "left": 16,
                "right": 16
              },
              "items": [
                {
                  "type": "image",
                  "image_url": "empty://",
                  "alignment_horizontal": "left",
                  "action_animation": {
                    "name": "native"
                  },
                  "paddings": {
                    "top": 5,
                    "bottom": 5,
                    "left": 5,
                    "right": 5
                  },
                  "tint_color": "@{paywall.title}",
                  "accessibility": {
                    "type": "button",
                    "mode": "merge",
                    "description": "Закрыть"
                  },
                  "action": {
                    "log_id": "paywall_button_close",
                    "url": "div-paywall://close"
                  },
                  "preview": "",
                  "width": {
                    "type": "fixed",
                    "value": 34
                  },
                  "height": {
                    "type": "fixed",
                    "value": 34
                  }
                },
                {
                  "type": "text",
                  "text": "Алиса нового поколения",
                  "margins": {
                    "right": 24
                  },
                  "text_color": "@{paywall.title}",
                  "font_size": 16,
                  "line_height": 20,
                  "font_weight": "bold",
                  "text_alignment_horizontal": "center",
                  "width": {
                    "type": "match_parent"
                  },
                  "accessibility": {
                    "description": "Голосовой помощник нового поколения",
                    "type": "header"
                  }
                }
              ]
            },
            {
              "type": "gallery",
              "id": "inner_content",
              "orientation": "vertical",
              "height": {
                "type": "match_parent"
              },
              "items": [
